"source": [
  "# ================================================================\n",
  "# PART 1. Data audit + build Event Master / Purchase Master\n",
  "# + session_level_funnel + customer_level_features\n",
  "# Schema aligned for downstream notebooks (02 / 03 / 04)\n",
  "# ================================================================\n",
  "import os\n",
  "import numpy as np\n",
  "import pandas as pd\n",
  "from IPython.display import display\n",
  "\n",
  "print(\"PART 1 start: clean dtypes -> build master tables -> build downstream tables -> save\")\n",
  "\n",
  "events_ = events.copy()\n",
  "customers_ = customers.copy()\n",
  "products_ = products.copy()\n",
  "campaigns_ = campaigns.copy()\n",
  "transactions_ = transactions.copy()\n",
  "\n",
  "customers_[\"signup_date\"] = pd.to_datetime(customers_[\"signup_date\"], errors=\"coerce\")\n",
  "products_[\"launch_date\"] = pd.to_datetime(products_[\"launch_date\"], errors=\"coerce\")\n",
  "campaigns_[\"start_date\"] = pd.to_datetime(campaigns_[\"start_date\"], errors=\"coerce\")\n",
  "campaigns_[\"end_date\"] = pd.to_datetime(campaigns_[\"end_date\"], errors=\"coerce\")\n",
  "events_[\"timestamp\"] = pd.to_datetime(events_[\"timestamp\"], errors=\"coerce\")\n",
  "transactions_[\"timestamp\"] = pd.to_datetime(transactions_[\"timestamp\"], errors=\"coerce\")\n",
  "\n",
  "for col in [\"customer_id\", \"product_id\", \"campaign_id\"]:\n",
  "    if col in events_.columns:\n",
  "        events_[col] = pd.to_numeric(events_[col], errors=\"coerce\")\n",
  "    if col in transactions_.columns:\n",
  "        transactions_[col] = pd.to_numeric(transactions_[col], errors=\"coerce\")\n",
  "    if col in customers_.columns:\n",
  "        customers_[col] = pd.to_numeric(customers_[col], errors=\"coerce\")\n",
  "    if col in products_.columns:\n",
  "        products_[col] = pd.to_numeric(products_[col], errors=\"coerce\")\n",
  "    if col in campaigns_.columns:\n",
  "        campaigns_[col] = pd.to_numeric(campaigns_[col], errors=\"coerce\")\n",
  "\n",
  "events_[\"campaign_id\"] = events_[\"campaign_id\"].fillna(0).astype(\"Int64\")\n",
  "transactions_[\"campaign_id\"] = transactions_[\"campaign_id\"].fillna(0).astype(\"Int64\")\n",
  "events_[\"customer_id\"] = events_[\"customer_id\"].astype(\"Int64\")\n",
  "events_[\"product_id\"] = events_[\"product_id\"].astype(\"Int64\")\n",
  "customers_[\"customer_id\"] = customers_[\"customer_id\"].astype(\"Int64\")\n",
  "products_[\"product_id\"] = products_[\"product_id\"].astype(\"Int64\")\n",
  "campaigns_[\"campaign_id\"] = campaigns_[\"campaign_id\"].astype(\"Int64\")\n",
  "transactions_[\"customer_id\"] = transactions_[\"customer_id\"].astype(\"Int64\")\n",
  "transactions_[\"product_id\"] = transactions_[\"product_id\"].astype(\"Int64\")\n",
  "\n",
  "if \"traffic_source\" in events_.columns:\n",
  "    events_[\"traffic_source\"] = (\n",
  "        events_[\"traffic_source\"].astype(\"string\").str.strip().str.lower().replace({\n",
  "            \"paid search\": \"paid_search\",\n",
  "            \"organic\": \"organic\",\n",
  "            \"email\": \"email\",\n",
  "            \"social\": \"social\",\n",
  "            \"direct\": \"direct\"\n",
  "        })\n",
  "    )\n",
  "\n",
  "events_[\"device_missing_flag\"] = events_[\"device_type\"].isna().astype(\"int8\")\n",
  "events_[\"device_type\"] = events_[\"device_type\"].fillna(\"Unknown\")\n",
  "events_[\"product_missing_flag\"] = events_[\"product_id\"].isna().astype(\"int8\")\n",
  "events_[\"is_product_related\"] = events_[\"product_id\"].notna().astype(\"int8\")\n",
  "events_[\"is_campaign_exposed\"] = (events_[\"campaign_id\"] != 0).astype(\"int8\")\n",
  "transactions_[\"is_campaign_order\"] = (transactions_[\"campaign_id\"] != 0).astype(\"int8\")\n",
  "events_[\"is_view\"] = (events_[\"event_type\"] == \"view\").astype(\"int8\")\n",
  "events_[\"is_click\"] = (events_[\"event_type\"] == \"click\").astype(\"int8\")\n",
  "events_[\"is_add_to_cart\"] = (events_[\"event_type\"] == \"add_to_cart\").astype(\"int8\")\n",
  "events_[\"is_purchase\"] = (events_[\"event_type\"] == \"purchase\").astype(\"int8\")\n",
  "events_[\"is_bounce\"] = (events_[\"event_type\"] == \"bounce\").astype(\"int8\")\n",
  "transactions_[\"revenue_sign_issue\"] = (((transactions_[\"refund_flag\"] == 1) & (transactions_[\"gross_revenue\"] > 0)) | ((transactions_[\"refund_flag\"] == 0) & (transactions_[\"gross_revenue\"] < 0))).astype(\"int8\")\n",
  "\n",
  "print(\"\\\\n[Basic diagnostics]\")\n",
  "print(f\"events_: {events_.shape}\")\n",
  "print(f\"customers_: {customers_.shape}\")\n",
  "print(f\"products_: {products_.shape}\")\n",
  "print(f\"campaigns_: {campaigns_.shape}\")\n",
  "print(f\"transactions_: {transactions_.shape}\")\n",
  "\n",
  "purchase_key_cols = [\"customer_id\", \"product_id\", \"timestamp\"]\n",
  "purchase_event_keys = events_.loc[events_[\"event_type\"] == \"purchase\", purchase_key_cols].copy()\n",
  "purchase_event_dup = purchase_event_keys.duplicated(subset=purchase_key_cols).sum()\n",
  "tx_key_dup = transactions_.duplicated(subset=purchase_key_cols).sum()\n",
  "print(f\"Duplicate purchase-event keys: {purchase_event_dup:,}\")\n",
  "print(f\"Duplicate transaction keys: {tx_key_dup:,}\")\n",
  "\n",
  "event_master = (\n",
  "    events_\n",
  "    .merge(customers_, on=\"customer_id\", how=\"left\", validate=\"m:1\")\n",
  "    .merge(products_, on=\"product_id\", how=\"left\", validate=\"m:1\")\n",
  "    .merge(campaigns_, on=\"campaign_id\", how=\"left\", validate=\"m:1\")\n",
  ")\n",
  "print(f\"event_master complete: {event_master.shape}\")\n",
  "\n",
  "purchase_events = event_master.loc[event_master[\"event_type\"] == \"purchase\"].copy()\n",
  "purchase_events_before = len(purchase_events)\n",
  "tx_agg = (\n",
  "    transactions_\n",
  "    .groupby([\"customer_id\", \"product_id\", \"timestamp\"], dropna=False, as_index=False)\n",
  "    .agg(\n",
  "        quantity=(\"quantity\", \"sum\"),\n",
  "        gross_revenue=(\"gross_revenue\", \"sum\"),\n",
  "        refund_flag=(\"refund_flag\", \"max\"),\n",
  "        campaign_id_tx=(\"campaign_id\", \"first\"),\n",
  "        is_campaign_order=(\"is_campaign_order\", \"max\"),\n",
  "        tx_row_count=(\"customer_id\", \"size\"),\n",
  "        revenue_sign_issue=(\"revenue_sign_issue\", \"max\")\n",
  "    )\n",
  ")\n",
  "purchase_master = purchase_events.merge(tx_agg, on=[\"customer_id\", \"product_id\", \"timestamp\"], how=\"left\", validate=\"m:1\")\n",
  "print(f\"purchase_master complete: {purchase_master.shape}\")\n",
  "\n",
  "match_rate = purchase_master[\"gross_revenue\"].notna().mean()\n",
  "matched = purchase_master[\"gross_revenue\"].notna()\n",
  "campaign_agree_rate = ((purchase_master.loc[matched, \"campaign_id\"] == purchase_master.loc[matched, \"campaign_id_tx\"]).mean() if matched.sum() > 0 else np.nan)\n",
  "unmatched_purchase = purchase_master[\"gross_revenue\"].isna().sum()\n",
  "\n",
  "event_master[\"event_date\"] = pd.to_datetime(event_master[\"timestamp\"], errors=\"coerce\").dt.date\n",
  "event_master[\"signup_to_event_days\"] = (pd.to_datetime(event_master[\"timestamp\"], errors=\"coerce\") - pd.to_datetime(event_master[\"signup_date\"], errors=\"coerce\")).dt.days\n",
  "event_master[\"product_age_days\"] = (pd.to_datetime(event_master[\"timestamp\"], errors=\"coerce\") - pd.to_datetime(event_master[\"launch_date\"], errors=\"coerce\")).dt.days\n",
  "event_master[\"campaign_active_flag\"] = np.where(event_master[\"campaign_id\"].fillna(0).astype(\"Int64\") == 0, 0, ((pd.to_datetime(event_master[\"timestamp\"], errors=\"coerce\") >= pd.to_datetime(event_master[\"start_date\"], errors=\"coerce\")) & (pd.to_datetime(event_master[\"timestamp\"], errors=\"coerce\") <= pd.to_datetime(event_master[\"end_date\"], errors=\"coerce\"))).astype(\"int8\"))\n",
  "purchase_master[\"gross_revenue_filled\"] = purchase_master[\"gross_revenue\"].fillna(0)\n",
  "purchase_master[\"quantity_filled\"] = purchase_master[\"quantity\"].fillna(0)\n",
  "purchase_master[\"refund_flag_filled\"] = purchase_master[\"refund_flag\"].fillna(0)\n",
  "purchase_master[\"net_revenue\"] = purchase_master[\"gross_revenue_filled\"]\n",
  "purchase_master[\"matched_tx_flag\"] = purchase_master[\"gross_revenue\"].notna().astype(\"int8\")\n",
  "\n",
  "def first_non_null(series):\n",
  "    s = series.dropna()\n",
  "    return s.iloc[0] if len(s) > 0 else np.nan\n",
  "\n",
  "def most_frequent(series):\n",
  "    s = series.dropna()\n",
  "    if len(s) == 0:\n",
  "        return np.nan\n",
  "    return s.mode().iloc[0]\n",
  "\n",
  "page_col = \"page_category\" if \"page_category\" in event_master.columns else None\n",
  "session_level_funnel = (\n",
  "    event_master.groupby(\"session_id\", dropna=False)\n",
  "    .agg(\n",
  "        customer_id=(\"customer_id\", \"first\"),\n",
  "        session_start_ts=(\"timestamp\", \"min\"),\n",
  "        session_end_ts=(\"timestamp\", \"max\"),\n",
  "        experiment_group=(\"experiment_group\", first_non_null),\n",
  "        session_campaign_id=(\"campaign_id\", \"max\"),\n",
  "        campaign_id=(\"campaign_id\", \"max\"),\n",
  "        is_campaign_exposed_session=(\"is_campaign_exposed\", \"max\"),\n",
  "        is_campaign_exposed=(\"is_campaign_exposed\", \"max\"),\n",
  "        first_device_type=(\"device_type\", first_non_null),\n",
  "        first_traffic_source=(\"traffic_source\", first_non_null),\n",
  "        preferred_device_type=(\"device_type\", most_frequent),\n",
  "        preferred_traffic_source=(\"traffic_source\", most_frequent),\n",
  "        n_events=(\"event_type\", \"size\"),\n",
  "        any_view=(\"is_view\", \"max\"),\n",
  "        any_click=(\"is_click\", \"max\"),\n",
  "        any_add_to_cart=(\"is_add_to_cart\", \"max\"),\n",
  "        any_purchase=(\"is_purchase\", \"max\"),\n",
  "        any_bounce=(\"is_bounce\", \"max\"),\n",
  "        total_views=(\"is_view\", \"sum\"),\n",
  "        total_clicks=(\"is_click\", \"sum\"),\n",
  "        total_add_to_cart=(\"is_add_to_cart\", \"sum\"),\n",
  "        total_purchases=(\"is_purchase\", \"sum\")\n",
  "    ).reset_index()\n",
  ")\n",
  "if page_col is not None:\n",
  "    first_page = event_master.groupby(\"session_id\", dropna=False)[page_col].agg(first_non_null).reset_index().rename(columns={page_col: \"first_page_category\"})\n",
  "    session_level_funnel = session_level_funnel.merge(first_page, on=\"session_id\", how=\"left\")\n",
  "else:\n",
  "    session_level_funnel[\"first_page_category\"] = \"Unknown\"\n",
  "session_level_funnel[\"first_page_category\"] = session_level_funnel[\"first_page_category\"].fillna(\"Unknown\")\n",
  "session_level_funnel[\"has_view\"] = session_level_funnel[\"any_view\"].astype(\"int8\")\n",
  "session_level_funnel[\"has_click\"] = session_level_funnel[\"any_click\"].astype(\"int8\")\n",
  "session_level_funnel[\"has_add_to_cart\"] = session_level_funnel[\"any_add_to_cart\"].astype(\"int8\")\n",
  "session_level_funnel[\"has_purchase\"] = session_level_funnel[\"any_purchase\"].astype(\"int8\")\n",
  "session_level_funnel[\"is_converted\"] = session_level_funnel[\"any_purchase\"].astype(\"int8\")\n",
  "session_level_funnel[\"wallclock_session_duration_sec\"] = (pd.to_datetime(session_level_funnel[\"session_end_ts\"], errors=\"coerce\") - pd.to_datetime(session_level_funnel[\"session_start_ts\"], errors=\"coerce\")).dt.total_seconds().fillna(0)\n",
  "session_level_funnel[\"avg_session_duration_sec\"] = session_level_funnel[\"wallclock_session_duration_sec\"]\n",
  "session_level_funnel[\"max_session_duration_sec\"] = session_level_funnel[\"wallclock_session_duration_sec\"]\n",
  "session_level_funnel[\"session_date\"] = pd.to_datetime(session_level_funnel[\"session_start_ts\"], errors=\"coerce\").dt.date.astype(str)\n",
  "session_level_funnel[\"funnel_stage\"] = np.select([session_level_funnel[\"any_purchase\"] == 1, session_level_funnel[\"any_add_to_cart\"] == 1, session_level_funnel[\"any_click\"] == 1, session_level_funnel[\"any_view\"] == 1, session_level_funnel[\"any_bounce\"] == 1], [\"purchase\", \"add_to_cart\", \"click\", \"view\", \"bounce\"], default=\"other\")\n",
  "\n",
  "if \"category\" in event_master.columns:\n",
  "    favorite_category_tbl = (event_master.dropna(subset=[\"customer_id\", \"category\"]).groupby([\"customer_id\", \"category\"]).size().reset_index(name=\"n\").sort_values([\"customer_id\", \"n\", \"category\"], ascending=[True, False, True]).drop_duplicates(\"customer_id\")[[\"customer_id\", \"category\"]].rename(columns={\"category\": \"favorite_category\"}))\n",
  "else:\n",
  "    favorite_category_tbl = customers_[[\"customer_id\"]].copy()\n",
  "    favorite_category_tbl[\"favorite_category\"] = \"Unknown\"\n",
  "\n",
  "customer_session_rollup = (session_level_funnel.groupby(\"customer_id\", dropna=False).agg(total_sessions=(\"session_id\", \"nunique\"), converted_sessions=(\"is_converted\", \"sum\"), total_views=(\"total_views\", \"sum\"), total_clicks=(\"total_clicks\", \"sum\"), total_add_to_cart=(\"total_add_to_cart\", \"sum\"), total_session_purchases=(\"total_purchases\", \"sum\"), ever_campaign_exposed=(\"is_campaign_exposed_session\", \"max\"), first_session_ts=(\"session_start_ts\", \"min\"), last_session_ts=(\"session_end_ts\", \"max\"), preferred_device_type=(\"preferred_device_type\", most_frequent), preferred_traffic_source=(\"preferred_traffic_source\", most_frequent)).reset_index())\n",
  "customer_purchase_rollup = (purchase_master.groupby(\"customer_id\", dropna=False).agg(total_orders=(\"matched_tx_flag\", \"sum\"), gross_revenue_total=(\"gross_revenue_filled\", \"sum\"), net_revenue_total=(\"net_revenue\", \"sum\"), refunded_orders=(\"refund_flag_filled\", \"sum\"), first_purchase_ts=(\"timestamp\", \"min\"), last_purchase_ts=(\"timestamp\", \"max\")).reset_index())\n",
  "if \"is_premium\" in purchase_master.columns:\n",
  "    premium_tbl = purchase_master.groupby(\"customer_id\", dropna=False).agg(premium_order_share=(\"is_premium\", lambda s: pd.to_numeric(s, errors=\"coerce\").fillna(0).mean())).reset_index()\n",
  "else:\n",
  "    premium_tbl = customers_[[\"customer_id\"]].copy()\n",
  "    premium_tbl[\"premium_order_share\"] = 0.0\n",
  "discount_proxy_tbl = session_level_funnel.groupby(\"customer_id\", dropna=False).agg(exposed_sessions=(\"is_campaign_exposed_session\", \"sum\"), total_sessions_tmp=(\"session_id\", \"nunique\")).reset_index()\n",
  "discount_proxy_tbl[\"discount_sensitivity_score\"] = np.where(discount_proxy_tbl[\"total_sessions_tmp\"] > 0, discount_proxy_tbl[\"exposed_sessions\"] / discount_proxy_tbl[\"total_sessions_tmp\"], 0.0)\n",
  "discount_proxy_tbl = discount_proxy_tbl[[\"customer_id\", \"discount_sensitivity_score\"]]\n",
  "customer_level_features = (customers_.merge(customer_session_rollup, on=\"customer_id\", how=\"left\").merge(customer_purchase_rollup, on=\"customer_id\", how=\"left\").merge(favorite_category_tbl, on=\"customer_id\", how=\"left\").merge(premium_tbl, on=\"customer_id\", how=\"left\").merge(discount_proxy_tbl, on=\"customer_id\", how=\"left\"))\n",
  "num_fill_zero = [\"total_sessions\", \"converted_sessions\", \"total_views\", \"total_clicks\", \"total_add_to_cart\", \"total_session_purchases\", \"ever_campaign_exposed\", \"total_orders\", \"gross_revenue_total\", \"net_revenue_total\", \"refunded_orders\", \"premium_order_share\", \"discount_sensitivity_score\"]\n",
  "for col in num_fill_zero:\n",
  "    if col in customer_level_features.columns:\n",
  "        customer_level_features[col] = pd.to_numeric(customer_level_features[col], errors=\"coerce\").fillna(0)\n",
  "str_fill_unknown = [\"favorite_category\", \"preferred_device_type\", \"preferred_traffic_source\", \"loyalty_tier\", \"country\", \"gender\", \"acquisition_channel\"]\n",
  "for col in str_fill_unknown:\n",
  "    if col in customer_level_features.columns:\n",
  "        customer_level_features[col] = customer_level_features[col].fillna(\"Unknown\")\n",
  "customer_level_features[\"has_purchase_history\"] = (customer_level_features[\"total_orders\"] > 0).astype(\"int8\")\n",
  "customer_level_features[\"customer_status\"] = np.where(customer_level_features[\"has_purchase_history\"] == 1, \"Existing_or_Buyer\", \"No_Purchase_History\")\n",
  "customer_level_features[\"session_conversion_rate\"] = np.where(customer_level_features[\"total_sessions\"] > 0, customer_level_features[\"converted_sessions\"] / customer_level_features[\"total_sessions\"], 0.0)\n",
  "customer_level_features[\"avg_order_value\"] = np.where(customer_level_features[\"total_orders\"] > 0, customer_level_features[\"net_revenue_total\"] / customer_level_features[\"total_orders\"], 0.0)\n",
  "\n",
  "os.makedirs(\"../data/processed\", exist_ok=True)\n",
  "print(\"\\nSaving outputs...\")\n",
  "event_master.to_parquet(\"../data/processed/event_master.parquet\", index=False)\n",
  "purchase_master.to_parquet(\"../data/processed/purchase_master.parquet\", index=False)\n",
  "session_level_funnel.to_parquet(\"../data/processed/session_level_funnel.parquet\", index=False)\n",
  "customer_level_features.to_parquet(\"../data/processed/customer_level_features.parquet\", index=False)\n",
  "event_master.to_csv(\"../data/processed/event_master.csv\", index=False)\n",
  "purchase_master.to_csv(\"../data/processed/purchase_master.csv\", index=False)\n",
  "session_level_funnel.to_csv(\"../data/processed/session_level_funnel.csv\", index=False)\n",
  "customer_level_features.to_csv(\"../data/processed/customer_level_features.csv\", index=False)\n",
  "\n",
  "print(\"Saved: event_master / purchase_master / session_level_funnel / customer_level_features\")\n",
  "print(\"\\n==================== Final Summary ====================\")\n",
  "print(f\"event_master rows                : {len(event_master):,}\")\n",
  "print(f\"purchase_master rows             : {len(purchase_master):,}\")\n",
  "print(f\"session_level_funnel rows        : {len(session_level_funnel):,}\")\n",
  "print(f\"customer_level_features rows     : {len(customer_level_features):,}\")\n",
  "print(f\"purchase tx match rate           : {match_rate:.2%}\")\n",
  "print(f\"transactions sign issue rows     : {transactions_['revenue_sign_issue'].sum():,}\")\n",
  "print(f\"purchase unmatched rows          : {unmatched_purchase:,}\")\n",
  "if matched.sum() > 0:\n",
  "    print(f\"campaign_id agreement rate       : {campaign_agree_rate:.2%}\")\n",
  "print(\"===================================================\")\n",
  "print(\"PART 1 complete: downstream notebooks (02 / 03 / 04) should now find the required tables and key columns.\")\n"
]
