    "# 0 means no campaign exposure, non-zero means exposed\n",
    "events['is_campaign_exposed'] = (events['campaign_id'] != 0).astype(int)\n",
    "transactions['is_campaign_order'] = (transactions['campaign_id'] != 0).astype(int)"
   ]
