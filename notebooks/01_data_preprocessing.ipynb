    "# 01 Data Preprocessing\n",
    "\n",
    "This notebook audits the raw ecommerce tables, cleans core fields, merges event and transaction data, and writes analysis-ready master tables to `../data/processed/`.\n",
    "\n",
    "**Expected raw inputs**\n",
    "- `campaigns.csv`\n",
    "- `customers.csv`\n",
    "- `events.csv`\n",
    "- `products.csv`\n",
    "- `transactions.csv`\n",
    "\n",
    "**Primary outputs**\n",
    "- `event_master.csv` / `event_master.parquet`\n",
    "- `purchase_master.csv` / `purchase_master.parquet`\n",
    "\n",
    "> Note: In the current uploaded workflow, `session_level_funnel.csv` and `customer_level_features.csv` are not generated here. Later notebooks assume they already exist under `data/processed/`.\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "267058bc",
   "metadata": {},
   "outputs": [],
   "source": [
    "import pandas as pd\n",
    "from IPython.display import display\n",
    "import os\n",
    "\n",
    "# 1. Set file paths (go one level up from notebooks to access data/raw)\n",
    "DATA_PATH = r\"../data/raw\"\n",
    "\n",
    "# 2. Load data\n",
    "print(\"📂 Loading data...\")\n",
    "try:\n",
    "    campaigns = pd.read_csv(os.path.join(DATA_PATH, 'campaigns.csv'))\n",
    "    customers = pd.read_csv(os.path.join(DATA_PATH, 'customers.csv'))\n",
    "    events = pd.read_csv(os.path.join(DATA_PATH, 'events.csv'))\n",
    "    products = pd.read_csv(os.path.join(DATA_PATH, 'products.csv'))\n",
    "    transactions = pd.read_csv(os.path.join(DATA_PATH, 'transactions.csv'))\n",
    "    print(\"✅ All files loaded successfully!\")\n",
    "except FileNotFoundError as e:\n",
    "    print(f\"❌ File path error: {e}\")\n",
    "    print(\"👉 Please make sure all five raw files are placed in data/raw.\")\n",
    "\n",
    "# 3. Data summary helper\n",
    "def summarize_data(name, df):\n",
    "    print(f\"\\n[{name.upper()} Summary]\")\n",
    "    print(f\"🔹 Shape (Rows, Cols): {df.shape}\")\n",
    "    print(f\"🔹 Null counts:\\n{df.isnull().sum()[df.isnull().sum() > 0]}\") # Show only columns with missing values\n",
    "    print(f\"🔹 Number of duplicated rows: {df.duplicated().sum()}\")\n",
    "    print(\"-\" * 30)\n",
    "    display(df.head(3))  # Inspect the first 3 rows\n",
    "\n",
    "# 4. Run diagnostics for all five files\n",
    "summarize_data(\"campaigns\", campaigns)\n",
    "summarize_data(\"customers\", customers)\n",
    "summarize_data(\"products\", products)\n",
    "summarize_data(\"transactions\", transactions)\n",
    "print(\"\\n(Events is large, so loading and display may take some time.)\")\n",
    "summarize_data(\"events\", events)"
   ]
  },
