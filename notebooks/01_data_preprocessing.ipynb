   "source": [
    "# =================================================================\n",
    "# 1. Clean transactions data (remove unusable ghost transactions)\n",
    "# =================================================================\n",
    "before_tx_cnt = len(transactions)\n",
    "\n",
    "# Drop rows without product_id or gross_revenue because they are not analytically useful\n",
    "transactions = transactions.dropna(subset=['product_id', 'gross_revenue'])\n",
    "\n",
    "after_tx_cnt = len(transactions)\n",
    "print(f\"✅ [Transactions] Removed {before_tx_cnt - after_tx_cnt:,} ghost rows (remaining: {after_tx_cnt:,})\")\n",
    "\n",
    "\n",
    "# =================================================================\n",
    "# 2. Clean events data (non-product activity and missing device info)\n",
    "# =================================================================\n",
    "# Product ID: define non-product activities (home, search, etc.) as -1\n",
    "events['product_id'] = events['product_id'].fillna(-1)\n",
    "\n",
    "# Device Type: label missing devices as 'Unknown'\n",
    "events['device_type'] = events['device_type'].fillna('Unknown')\n",
    "\n",
    "print(f\"✅ [Events] Filled missing Product ID and Device Type values\")"
   ]
  },
  {
