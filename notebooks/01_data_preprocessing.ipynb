    "# 5. Check refund logic (find refund rows with positive revenue)\n",
    "wrong_refunds = transactions[(transactions['refund_flag'] == 1) & (transactions['gross_revenue'] > 0)]\n",
    "print(f\"⚠️ Refund logic issues found: {len(wrong_refunds)} rows\")"
   ]
  },
  {
