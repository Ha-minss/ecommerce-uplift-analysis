   "source": [
    "# (Optional) Normalize invalid refund rows by flipping revenue to negative\n",
    "if len(wrong_refunds) > 0:\n",
    "    transactions.loc[(transactions['refund_flag'] == 1) & (transactions['gross_revenue'] > 0), 'gross_revenue'] *= -1\n",
    "    print(\"✅ Corrected invalid refund revenues to negative values.\")"
   ]
  },
  {
