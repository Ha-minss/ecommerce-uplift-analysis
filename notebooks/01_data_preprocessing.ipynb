   "source": [
    "# ================================================================\n",
    "# PART 1. Data audit + build Event Master / Purchase Master + validation\n",
    "# Assumption: events, customers, products, campaigns, and transactions are already loaded\n",
    "# ================================================================\n",
    "import os\n",
    "import numpy as np\n",
    "import pandas as pd\n",
    "from IPython.display import display\n",
    "\n",
    "print(\"🚀 PART 1 start: clean dtypes → build master tables → validate → save\")\n",
    "\n",
    "# ----------------------------------------------------------------\n",
    "# 0) Copy inputs to protect the originals\n",
    "# ----------------------------------------------------------------\n",
    "events_ = events.copy()\n",
    "customers_ = customers.copy()\n",
    "products_ = products.copy()\n",
    "campaigns_ = campaigns.copy()\n",
    "transactions_ = transactions.copy()\n",
    "\n",
    "# ----------------------------------------------------------------\n",
    "# 1) Clean date and dtype fields\n",
    "# ----------------------------------------------------------------\n",
    "customers_[\"signup_date\"] = pd.to_datetime(customers_[\"signup_date\"], errors=\"coerce\")\n",
    "products_[\"launch_date\"] = pd.to_datetime(products_[\"launch_date\"], errors=\"coerce\")\n",
    "campaigns_[\"start_date\"] = pd.to_datetime(campaigns_[\"start_date\"], errors=\"coerce\")\n",
    "campaigns_[\"end_date\"] = pd.to_datetime(campaigns_[\"end_date\"], errors=\"coerce\")\n",
    "\n",
    "events_[\"timestamp\"] = pd.to_datetime(events_[\"timestamp\"], errors=\"coerce\")\n",
    "transactions_[\"timestamp\"] = pd.to_datetime(transactions_[\"timestamp\"], errors=\"coerce\")\n",
    "\n",
    "# Standardize key dtypes\n",
    "events_[\"customer_id\"] = pd.to_numeric(events_[\"customer_id\"], errors=\"coerce\").astype(\"Int64\")\n",
    "customers_[\"customer_id\"] = pd.to_numeric(customers_[\"customer_id\"], errors=\"coerce\").astype(\"Int64\")\n",
    "\n",
    "events_[\"product_id\"] = pd.to_numeric(events_[\"product_id\"], errors=\"coerce\").astype(\"Int64\")\n",
    "products_[\"product_id\"] = pd.to_numeric(products_[\"product_id\"], errors=\"coerce\").astype(\"Int64\")\n",
    "\n",
    "events_[\"campaign_id\"] = pd.to_numeric(events_[\"campaign_id\"], errors=\"coerce\").fillna(0).astype(\"Int64\")\n",
    "campaigns_[\"campaign_id\"] = pd.to_numeric(campaigns_[\"campaign_id\"], errors=\"coerce\").astype(\"Int64\")\n",
    "\n",
    "transactions_[\"customer_id\"] = pd.to_numeric(transactions_[\"customer_id\"], errors=\"coerce\").astype(\"Int64\")\n",
    "transactions_[\"product_id\"] = pd.to_numeric(transactions_[\"product_id\"], errors=\"coerce\").astype(\"Int64\")\n",
    "transactions_[\"campaign_id\"] = pd.to_numeric(transactions_[\"campaign_id\"], errors=\"coerce\").fillna(0).astype(\"Int64\")\n",
    "\n",
    "# ----------------------------------------------------------------\n",
    "# 2) Clean string fields and create flags\n",
    "# ----------------------------------------------------------------\n",
    "# Standardize traffic_source labels\n",
    "events_[\"traffic_source\"] = (\n",
    "    events_[\"traffic_source\"]\n",
    "    .astype(\"string\")\n",
    "    .str.strip()\n",
    "    .str.lower()\n",
    "    .replace({\n",
    "        \"paid search\": \"paid_search\",\n",
    "        \"organic\": \"organic\",\n",
    "        \"email\": \"email\",\n",
    "        \"social\": \"social\",\n",
    "        \"direct\": \"direct\"\n",
    "    })\n",
    ")\n",
    "\n",
    "# Flag missing device_type values\n",
    "events_[\"device_missing_flag\"] = events_[\"device_type\"].isna().astype(\"int8\")\n",
    "events_[\"device_type\"] = events_[\"device_type\"].fillna(\"Unknown\")\n",
    "\n",
    "# Product-related flags\n",
    "events_[\"product_missing_flag\"] = events_[\"product_id\"].isna().astype(\"int8\")\n",
    "events_[\"is_product_related\"] = events_[\"product_id\"].notna().astype(\"int8\")\n",
    "\n",
    "# Campaign exposure flags\n",
    "events_[\"is_campaign_exposed\"] = (events_[\"campaign_id\"] != 0).astype(\"int8\")\n",
    "transactions_[\"is_campaign_order\"] = (transactions_[\"campaign_id\"] != 0).astype(\"int8\")\n",
    "\n",
    "# Core event-type flags\n",
    "events_[\"is_view\"] = (events_[\"event_type\"] == \"view\").astype(\"int8\")\n",
    "events_[\"is_click\"] = (events_[\"event_type\"] == \"click\").astype(\"int8\")\n",
    "events_[\"is_add_to_cart\"] = (events_[\"event_type\"] == \"add_to_cart\").astype(\"int8\")\n",
    "events_[\"is_purchase\"] = (events_[\"event_type\"] == \"purchase\").astype(\"int8\")\n",
    "events_[\"is_bounce\"] = (events_[\"event_type\"] == \"bounce\").astype(\"int8\")\n",
    "\n",
    "# Validation flag for transactions: refund sign consistency\n",
    "transactions_[\"revenue_sign_issue\"] = (\n",
    "    ((transactions_[\"refund_flag\"] == 1) & (transactions_[\"gross_revenue\"] > 0)) |\n",
    "    ((transactions_[\"refund_flag\"] == 0) & (transactions_[\"gross_revenue\"] < 0))\n",
    ").astype(\"int8\")\n",
    "\n",
    "# ----------------------------------------------------------------\n",
    "# 3) Basic diagnostics\n",
    "# ----------------------------------------------------------------\n",
    "print(\"\\n[Basic diagnostics]\")\n",
    "print(f\"events_        : {events_.shape}\")\n",
    "print(f\"customers_     : {customers_.shape}\")\n",
    "print(f\"products_      : {products_.shape}\")\n",
    "print(f\"campaigns_     : {campaigns_.shape}\")\n",
    "print(f\"transactions_  : {transactions_.shape}\")\n",
    "\n",
    "print(\"\\n[Transactions refund sign issues]\")\n",
    "print(f\"revenue_sign_issue Total: {transactions_['revenue_sign_issue'].sum():,}\")\n",
    "\n",
    "# Check duplicate purchase keys\n",
    "purchase_key_cols = [\"customer_id\", \"product_id\", \"timestamp\"]\n",
    "purchase_event_keys = events_.loc[events_[\"event_type\"] == \"purchase\", purchase_key_cols].copy()\n",
    "purchase_event_dup = purchase_event_keys.duplicated(subset=purchase_key_cols).sum()\n",
    "\n",
    "tx_key_dup = transactions_.duplicated(subset=purchase_key_cols).sum()\n",
    "\n",
    "print(\"\\n[Key duplicate diagnostics]\")\n",
    "print(f\"Duplicate purchase-event keys(customer_id, product_id, timestamp): {purchase_event_dup:,}\")\n",
    "print(f\"Duplicate transaction keys(customer_id, product_id, timestamp): {tx_key_dup:,}\")\n",
    "\n",
    "# ----------------------------------------------------------------\n",
    "# 4) Build Event Master\n",
    "#    For behavior analysis: events + customers + products + campaigns\n",
    "# ----------------------------------------------------------------\n",
    "print(\"\\n🏗️ Building event_master...\")\n",
    "\n",
    "event_master = (\n",
    "    events_\n",
    "    .merge(customers_, on=\"customer_id\", how=\"left\", validate=\"m:1\")\n",
    "    .merge(products_, on=\"product_id\", how=\"left\", validate=\"m:1\")\n",
    "    .merge(campaigns_, on=\"campaign_id\", how=\"left\", validate=\"m:1\")\n",
    ")\n",
    "\n",
    "print(f\"✅ event_master complete: {event_master.shape}\")\n",
    "\n",
    "# ----------------------------------------------------------------\n",
    "# 5) Build Purchase Master\n",
    "#    For revenue analysis: purchase events + transactions\n",
    "#    Key match: customer_id + product_id + timestamp\n",
    "# ----------------------------------------------------------------\n",
    "print(\"\\n🛒 Building purchase_master...\")\n",
    "\n",
    "purchase_events = event_master.loc[event_master[\"event_type\"] == \"purchase\"].copy()\n",
    "purchase_events_before = len(purchase_events)\n",
    "\n",
    "# Aggregate tx rows when keys are duplicated, then merge with unique keys\n",
    "tx_agg = (\n",
    "    transactions_\n",
    "    .groupby([\"customer_id\", \"product_id\", \"timestamp\"], dropna=False, as_index=False)\n",
    "    .agg(\n",
    "        quantity=(\"quantity\", \"sum\"),\n",
    "        gross_revenue=(\"gross_revenue\", \"sum\"),\n",
    "        refund_flag=(\"refund_flag\", \"max\"),\n",
    "        campaign_id_tx=(\"campaign_id\", \"first\"),\n",
    "        is_campaign_order=(\"is_campaign_order\", \"max\"),\n",
    "        tx_row_count=(\"customer_id\", \"size\"),\n",
    "        revenue_sign_issue=(\"revenue_sign_issue\", \"max\")\n",
    "    )\n",
    ")\n",
    "\n",
    "purchase_master = purchase_events.merge(\n",
    "    tx_agg,\n",
    "    on=[\"customer_id\", \"product_id\", \"timestamp\"],\n",
    "    how=\"left\",\n",
    "    validate=\"m:1\"\n",
    ")\n",
    "\n",
    "print(f\"✅ purchase_master complete: {purchase_master.shape}\")\n",
    "\n",
    "# ----------------------------------------------------------------\n",
    "# 6) Validation\n",
    "# ----------------------------------------------------------------\n",
    "print(\"\\n[Validation 1] Check purchase row count preservation\")\n",
    "print(f\"purchase_events rows : {purchase_events_before:,}\")\n",
    "print(f\"purchase_master rows : {len(purchase_master):,}\")\n",
    "print(f\"row delta            : {len(purchase_master) - purchase_events_before:,}\")\n",
    "\n",
    "print(\"\\n[Validation 2] Transaction match rate\")\n",
    "match_rate = purchase_master[\"gross_revenue\"].notna().mean()\n",
    "print(f\"purchase event → transaction match rate: {match_rate:.2%}\")\n",
    "\n",
    "print(\"\\n[Validation 3] Campaign ID agreement rate (matched rows only)\")\n",
    "matched = purchase_master[\"gross_revenue\"].notna()\n",
    "if matched.sum() > 0:\n",
    "    campaign_agree_rate = (purchase_master.loc[matched, \"campaign_id\"] == purchase_master.loc[matched, \"campaign_id_tx\"]).mean()\n",
    "    print(f\"campaign_id agreement rate: {campaign_agree_rate:.2%}\")\n",
    "else:\n",
    "    print(\"No matched transactions, so campaign_id agreement could not be computed.\")\n",
    "\n",
    "print(\"\\n[Validation 4] Count purchase rows without matched transactions\")\n",
    "unmatched_purchase = purchase_master[\"gross_revenue\"].isna().sum()\n",
    "print(f\"unmatched purchase rows: {unmatched_purchase:,}\")\n",
    "\n",
    "print(\"\\n[Validation 5] Check whether one transaction expanded into multiple rows\")\n",
    "multi_tx_match = (purchase_master[\"tx_row_count\"] > 1).sum(skipna=True)\n",
    "print(f\"tx_row_count > 1 purchase rows: {multi_tx_match:,}\")\n",
    "\n",
    "print(\"\\n[Validation 6] Inspect purchase sample rows\")\n",
    "display_cols = [\n",
    "    \"customer_id\", \"product_id\", \"timestamp\", \"campaign_id\", \"campaign_id_tx\",\n",
    "    \"gross_revenue\", \"quantity\", \"refund_flag\", \"tx_row_count\"\n",
    "]\n",
    "display(purchase_master[display_cols].head(10))\n",
    "\n",
    "# ----------------------------------------------------------------\n",
    "# 7) Add analysis-friendly derived variables\n",
    "# ----------------------------------------------------------------\n",
    "print(\"\\n🧠 Creating derived variables for analysis...\")\n",
    "\n",
    "# event_master side\n",
    "event_master[\"event_date\"] = event_master[\"timestamp\"].dt.date\n",
    "event_master[\"signup_to_event_days\"] = (event_master[\"timestamp\"] - event_master[\"signup_date\"]).dt.days\n",
    "event_master[\"product_age_days\"] = (event_master[\"timestamp\"] - event_master[\"launch_date\"]).dt.days\n",
    "event_master[\"campaign_active_flag\"] = np.where(\n",
    "    event_master[\"campaign_id\"].fillna(0).astype(\"Int64\") == 0,\n",
    "    0,\n",
    "    (\n",
    "        (event_master[\"timestamp\"] >= event_master[\"start_date\"]) &\n",
    "        (event_master[\"timestamp\"] <= event_master[\"end_date\"])\n",
    "    ).astype(\"int8\")\n",
    ")\n",
    "\n",
    "# purchase_master side\n",
    "purchase_master[\"gross_revenue_filled\"] = purchase_master[\"gross_revenue\"].fillna(0)\n",
    "purchase_master[\"quantity_filled\"] = purchase_master[\"quantity\"].fillna(0)\n",
    "purchase_master[\"refund_flag_filled\"] = purchase_master[\"refund_flag\"].fillna(0)\n",
    "purchase_master[\"net_revenue\"] = purchase_master[\"gross_revenue_filled\"]  # Assume refunds are already represented as negative values\n",
    "purchase_master[\"matched_tx_flag\"] = purchase_master[\"gross_revenue\"].notna().astype(\"int8\")\n",
    "\n",
    "# ----------------------------------------------------------------\n",
    "# 8) Save outputs\n",
    "# ----------------------------------------------------------------\n",
    "import os\n",
    "\n",
    "os.makedirs(\"../data/processed\", exist_ok=True)\n",
    "\n",
    "print(\"\\nSaving outputs...\")\n",
    "\n",
    "# Always save the two core master tables\n",
    "event_master.to_parquet(\"../data/processed/event_master.parquet\", index=False)\n",
    "purchase_master.to_parquet(\"../data/processed/purchase_master.parquet\", index=False)\n",
    "\n",
    "event_master.to_csv(\"../data/processed/event_master.csv\", index=False)\n",
    "purchase_master.to_csv(\"../data/processed/purchase_master.csv\", index=False)\n",
    "\n",
    "print(\"Saved: event_master / purchase_master (parquet + csv)\")\n",
    "\n",
    "# Save session-level funnel table if it exists\n",
    "if \"session_level_funnel\" in globals():\n",
    "    session_level_funnel.to_parquet(\"../data/processed/session_level_funnel.parquet\", index=False)\n",
    "    session_level_funnel.to_csv(\"../data/processed/session_level_funnel.csv\", index=False)\n",
    "    print(\"Saved: session_level_funnel (parquet + csv)\")\n",
    "else:\n",
    "    print(\"session_level_funnel was not found in memory.\")\n",
    "\n",
    "# Save customer-level feature table if it exists\n",
    "if \"customer_level_features\" in globals():\n",
    "    customer_level_features.to_parquet(\"../data/processed/customer_level_features.parquet\", index=False)\n",
    "    customer_level_features.to_csv(\"../data/processed/customer_level_features.csv\", index=False)\n",
    "    print(\"Saved: customer_level_features (parquet + csv)\")\n",
    "else:\n",
    "    print(\"customer_level_features was not found in memory.\")\n"
    "# ----------------------------------------------------------------\n",
    "# 9) Final summary\n",
    "# ----------------------------------------------------------------\n",
    "print(\"\\n==================== Final Summary ====================\")\n",
    "print(f\"event_master rows                : {len(event_master):,}\")\n",
    "print(f\"purchase_master rows             : {len(purchase_master):,}\")\n",
    "print(f\"purchase tx match rate           : {match_rate:.2%}\")\n",
    "print(f\"transactions sign issue rows     : {transactions_['revenue_sign_issue'].sum():,}\")\n",
    "print(f\"purchase unmatched rows          : {unmatched_purchase:,}\")\n",
    "if matched.sum() > 0:\n",
    "    print(f\"campaign_id agreement rate       : {campaign_agree_rate:.2%}\")\n",
    "print(\"===================================================\")\n",
    "print(\"🎉 PART 1 complete: you can now move to PART 2 (Funnel / Cohort / Segment EDA)\")"
   ]
  }
 ],
